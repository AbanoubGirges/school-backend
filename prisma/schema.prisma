// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // @ts-ignore
  url      = env("DIRECT_URL")
}

// user model
enum Gender {
  MALE
  FEMALE
}

enum Role {
  SUDO
  ADMIN
  USER
  FATHER
}

enum Status {
  PENDING
  REJECTED
  APPROVED
}

model User {
  id                 String   @id @default(uuid())
  userName           String   @unique
  password           String
  name               String
  gender             Gender
  birthdate          DateTime
  address            String
  role               Role
  whatsapp           String
  phoneNumber        String      @unique
  homeNumber         String?
  schoolName         String
  educationType      String
  educationYear      String
  confessionFather   String
  liturgyDate        String
  servantPrepYear    String
  serviceType        String
  registerDate       DateTime @default(now())
  status             Status     @default(PENDING)
  attendances        Attendance[]
}

//attendance model
enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSEDLATE
  UNEXCUSEDLATE
}
model Attendance {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @unique @default(now())
  status      AttendanceStatus
  user        User     @relation(fields: [userId], references: [id])
  note     String?
}
//lectures model
model Lecture {
  id          String   @id @default(uuid())
  title       String
  type        String
  date        DateTime
  path         String @unique
  subject     Subject
}
//subjects enum
enum Subject {
  BIBLE
  SERVICE_TOPICS
  DOCTRINE
  CHURCH_HISTORY
  RITUALS
  HYMNS
}